square(n)
{
    return n * n;
};

center_x = 20;
center_y = 20;

screen_width = 80;
screen_height = 45;

pixel = 150;

circle_width = 11;

x = 0;
while(x < screen_width)
{
    y = 0;

    while(y < screen_height)
    {
        if(square(x - center_x) + square(y - center_y) < square(circle_width))
        {
            set(x, y, pixel);
        };

        y = y + 1;
    };

    x = x + 1;
};

draw;